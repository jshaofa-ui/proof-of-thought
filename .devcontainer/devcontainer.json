{
  "name": "Open Agents Development",

  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/open-agents",

  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "installOhMyZsh": true,
      "configureZshAsDefaultShell": true,
      "upgradePackages": true
    },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "moby": true,
      "dockerDashComposeVersion": "v2"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts",
      "nodeGypDependencies": true,
      "installYarnUsingApt": true
    },
    "ghcr.io/devcontainers/features/go:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.11",
      "installTools": true
    },
    "ghcr.io/rocker-org/devcontainer-features/apt-packages:1": {
      "packages": "jq,unzip,python3-dev,python3-venv"
    }
  },

  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "editor.formatOnSave": true,
        "editor.rulers": [80, 120],
        "files.trimTrailingWhitespace": true,
        "files.insertFinalNewline": true,
        "[javascript]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode",
          "editor.formatOnSave": true
        },
        "[typescript]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode",
          "editor.formatOnSave": true
        },
        "[typescriptreact]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode",
          "editor.formatOnSave": true
        },
        "[json]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode",
          "editor.formatOnSave": true
        },
        "[jsonc]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode",
          "editor.formatOnSave": true
        },
        "[solidity]": {
          "editor.defaultFormatter": "NomicFoundation.hardhat-solidity",
          "editor.formatOnSave": true
        },
        "solidity.compileUsingRemoteVersion": "latest",
        "solidity.formatter": "forge",
        "[python]": {
          "editor.defaultFormatter": "ms-python.black-formatter",
          "editor.formatOnSave": true
        }
      },

      "extensions": [
        "NomicFoundation.hardhat-solidity",
        "ms-azuretools.vscode-docker",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint",
        "eamodio.gitlens",
        "github.vscode-pull-request-github",
        "gruntfuggly.todo-tree",
        "ms-python.python",
        "ms-python.black-formatter",
        "christian-kohler.path-intellisense",
        "yzhang.markdown-all-in-one",
        "davidanson.vscode-markdownlint",
        "editorconfig.editorconfig"
      ]
    }
  },

  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:/home/vscode/.foundry/bin:/home/vscode/axl-nodes:/home/vscode/go/bin:/home/vscode/.local/bin",
    "EDITOR": "code --wait",
    "KV_URL": "redis://redis:6379",

    "KEEPERHUB_API_KEY": "${localEnv:KEEPERHUB_API_KEY}",
    "KEEPERHUB_URL": "${localEnv:KEEPERHUB_URL}",
    "PRIVATE_KEY": "${localEnv:PRIVATE_KEY}",
    "X402_FACILITATOR_URL": "${localEnv:X402_FACILITATOR_URL}",
    "AXL_HOST": "${localEnv:AXL_HOST}",
    "AXL_PEER_KEY": "${localEnv:AXL_PEER_KEY}",
    "OG_RPC_URL": "${localEnv:OG_RPC_URL}",
    "OG_PRIVATE_KEY": "${localEnv:OG_PRIVATE_KEY}",
    "UNISWAP_RPC_URL": "${localEnv:UNISWAP_RPC_URL}",

    "ALCHEMY_API_KEY": "${localEnv:ALCHEMY_API_KEY}",
    "ETHERSCAN_API_KEY": "${localEnv:ETHERSCAN_API_KEY}"
  },

  "postCreateCommand": "bash -lc \"echo '[postCreate] installing npm dependencies' && npm install && echo '[postCreate] installing Python dependencies' && uv sync && echo '[postCreate] verifying AXL binary' && (axl --help > /dev/null 2>&1 && echo 'AXL binary OK' || echo 'WARN: AXL binary not found — rebuild from https://github.com/gensyn-ai/axl') && echo '[postCreate] done'\"",

  "postStartCommand": "echo '[postStart] DevContainer ready. Redis at redis:6379. AXL binaries at ~/axl-nodes/axl'",

  "shutdownAction": "stopCompose",

  "mounts": [
    {
      "source": "open-agents-dev-home-data",
      "target": "/home/vscode",
      "type": "volume"
    },
    {
      "source": "open-agents-dev-docker-data",
      "target": "/var/lib/docker",
      "type": "volume"
    }
  ],

  "runArgs": [
    "--privileged",
    "--hostname=open-agents-dev",
    "--name=open-agents-dev",
    "--init"
  ],

  "remoteUser": "vscode",

  "forwardPorts": [3000, 3001, 8545, 9002, 9003],

  "portsAttributes": {
    "3000": {
      "label": "App Server",
      "onAutoForward": "notify"
    },
    "3001": {
      "label": "MCP Server",
      "onAutoForward": "notify"
    },
    "8545": {
      "label": "Local Blockchain (Anvil)",
      "onAutoForward": "silent"
    },
    "9002": {
      "label": "AXL Node A",
      "onAutoForward": "notify"
    },
    "9003": {
      "label": "AXL Node B",
      "onAutoForward": "notify"
    }
  }
}
